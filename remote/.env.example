# Copy this file to .env and fill in your values
TG_BOT_TOKEN="your-telegram-bot-token-from-botfather"
TG_USER_ID="your-telegram-user-id-from-userinfobot"

# Optional settings
# CLAUDE_CMD="claude"          # path to claude binary
# DISPATCH_TIMEOUT="60"        # seconds to wait for claude -p
# CAPTURE_LINES="40"           # lines to capture from tmux pane
